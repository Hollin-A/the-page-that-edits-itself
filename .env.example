# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# GitHub — fine-grained PAT scoped to this repo (contents: write, pull_requests: write)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Rate limiting — max comment submissions per IP per hour (default: 3 for anon, 20 for signed-in)
RATE_LIMIT_PER_HOUR=
NEXT_PUBLIC_ANON_RATE_LIMIT=3

# GitHub OAuth app — used for visitor sign-in
# Create at: github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://your-domain.com/api/auth/callback/github (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=
